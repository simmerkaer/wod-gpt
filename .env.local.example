# Copy to .env.local and fill in (same values as Azure Static Web App → Configuration).
# Required for Google login when running: npm run start  → open http://localhost:4280
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated; must match API ADMIN_EMAILS. Shows /admin nav only for these users.
VITE_ADMIN_EMAILS=simmerkaer@gmail.com
